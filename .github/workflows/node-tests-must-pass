name: Test People XD Client

run-name: ${{ github.actor }} is running client tests

on:
  workflow_dispatch:
  pull_request:
    branches:
      - develop
      - main
  push:
    branches:
      - main
      - develop

jobs:
  build-test-client:
    runs-on: ubuntu-latest
    container: node:22
    steps:
      - run: node -v
      - run: npm -v
      - name: Check out repository code
        uses: actions/checkout@v4
      - run: pwd
      - run: ls
      - name: Install Dependencies
        working-directory: node-app
        run: npm install
      - name: Run Client Tests 
        working-directory: node-app
        run: npm test